FROM golang:1.22-alpine AS builder

WORKDIR /app

COPY services/event-normalizer/go.mod services/event-normalizer/go.sum ./
RUN go mod download

COPY services/event-normalizer/ ./
RUN CGO_ENABLED=0 GOOS=linux go build -o /worker ./cmd/worker

FROM alpine:3.19

RUN apk --no-cache add ca-certificates tzdata

WORKDIR /app

COPY --from=builder /worker .

EXPOSE 8081

CMD ["./worker"]
