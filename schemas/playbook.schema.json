{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://zk-xdr-graph.io/schemas/playbook.schema.json",
  "title": "SOAR Playbook",
  "description": "SOAR playbook definition for automated response",
  "type": "object",
  "required": ["id", "name", "trigger", "actions"],
  "properties": {
    "id": {
      "type": "string",
      "description": "Playbook identifier"
    },
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "version": {
      "type": "string",
      "default": "0.1.0"
    },
    "trigger": {
      "type": "object",
      "properties": {
        "event_type": { "type": "string" },
        "risk_score_gte": { "type": "number" }
      }
    },
    "conditions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "field": { "type": "string" },
          "operator": { "type": "string", "enum": ["eq", "neq", "in", "not_in", "gte", "lte", "gt", "lt"] },
          "value": {}
        }
      }
    },
    "actions": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string" },
          "target": { "type": "string" },
          "tag": { "type": "string" },
          "queue": { "type": "string" },
          "title": { "type": "string" }
        }
      }
    },
    "approval": {
      "type": "object",
      "properties": {
        "required": { "type": "boolean" },
        "approver_role": { "type": "string" }
      }
    }
  }
}
